# Database
DATABASE_URL="postgresql://user:password@localhost:5432/abstrabit?schema=public"

# GitHub OAuth
GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"
GITHUB_REDIRECT_URI="http://localhost:8000/api/auth/callback"

# Frontend
FRONTEND_URL="http://localhost:5173"

# Security
ENCRYPTION_KEY="your-32-character-encryption-key-here!"
SESSION_SECRET="your-32-character-session-secret-here!"
WEBHOOK_SECRET="your_webhook_secret_min_8_chars"

# Public API URL (where GitHub sends webhooks — must be publicly reachable)
API_URL="https://your-app.onrender.com"

# AI (optional — enables auto-triage of issues/PRs)
OPENROUTER_API_KEY="your_openrouter_api_key"
