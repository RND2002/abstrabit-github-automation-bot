{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "dotenv -e ../.env.local -- tsx watch src/server.ts",
    "dev:prod": "dotenv -e ../.env.prod -- tsx watch src/server.ts",
    "build": "tsc",
    "start": "dotenv -e ../.env.prod -- node dist/server.js",
    "start:local": "dotenv -e ../.env.local -- node dist/server.js",
    "local": "dotenv -e ../.env.local -- nodemon --watch src -e ts --exec tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "dotenv -e ../.env.local -- prisma generate",
    "db:migrate": "dotenv -e ../.env.local -- prisma migrate dev",
    "db:push": "dotenv -e ../.env.local -- prisma db push",
    "db:studio": "dotenv -e ../.env.local -- prisma studio",
    "db:migrate:prod": "dotenv -e ../.env.prod -- prisma migrate deploy"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.3",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "axios": "^1.18.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "nodemon": "^3.1.14",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}